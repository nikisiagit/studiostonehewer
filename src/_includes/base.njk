<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title | default("Studio Stonehewer") }}</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div class="cursor"></div>

  {% if not isHome %}
  <nav class="navbar" style="position: sticky; background-color: var(--color-bg);">
    <a href="/" class="nav-brand">
      <img src="{{ settings.nav_logo }}" alt="Studio Stonehewer Logo" class="nav-logo" style="filter: none; mix-blend-mode: normal; height: 35px;">
      STUDIO STONEHEWER
    </a>
    <div class="menu-toggle" id="mobile-menu">
      <span class="bar"></span>
      <span class="bar"></span>
    </div>
    <div class="nav-links">
      {% for link in settings.nav_links %}
      <a href="{{ link.url }}">{{ link.label }}</a>
      {% endfor %}
    </div>
  </nav>
  {% endif %}

  {{ content | safe }}

  <!-- Footer -->
  <footer class="footer-section reveal">
    <div class="container">
      <h3 class="footer-title">Studio Stonehewer</h3>
      <p class="footer-desc">Interior design rooted in curated and expressive moments to tell the stories of your home.</p>
      <div class="footer-contact">
        <a href="mailto:studiostonehewer@gmail.com">STUDIOSTONEHEWER@GMAIL.COM</a>
        <a href="#">INSTAGRAM</a>
      </div>
      <div class="footer-links">
        {% for link in settings.nav_links %}
        <a href="{{ link.url }}">{{ link.label }}</a>
        {% endfor %}
      </div>
      <p class="copyright">© 2026 Studio Stonehewer. All rights reserved.</p>
    </div>
  </footer>

  <script src="/script.js"></script>
</body>
</html>
