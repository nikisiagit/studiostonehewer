<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ seo_title | default(title) | default(settings.site_title) }}</title>
  <meta name="description" content="{{ seo_description | default(settings.site_description) }}">
  
  <!-- Open Graph / Social Media Meta Tags -->
  <meta property="og:title" content="{{ seo_title | default(title) | default(settings.site_title) }}">
  <meta property="og:description" content="{{ seo_description | default(settings.site_description) }}">
  <meta property="og:image" content="{{ seo_image | default(settings.site_image) }}">
  <meta property="og:type" content="website">
  
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,400&family=Inter:wght@300;400;500&display=swap">
  <link rel="stylesheet" href="/styles.css">
  {% if isHome %}
  <link rel="preload" as="image" href="{{ hero_left_image | resizeImage(1200, 85) }}">
  <link rel="preload" as="image" href="{{ hero_right_image | resizeImage(1200, 85) }}">
  {% endif %}
</head>
<body>
  <div class="cursor"></div>

  {% if not isHome %}
  <nav class="navbar" style="position: sticky; background-color: var(--color-bg);">
    <a href="/" class="nav-brand">
      <img src="{{ settings.nav_logo | resizeImage(300, 90) }}" alt="Studio Stonehewer Logo" class="nav-logo">
      <span>STUDIO<br>STONEHEWER</span>
    </a>
    <div class="menu-toggle" id="mobile-menu">
      <span class="bar"></span>
      <span class="bar"></span>
    </div>
    <div class="nav-links">
      {% for link in settings.nav_links %}
      <a href="{{ link.url }}">{{ link.label }}</a>
      {% endfor %}
    </div>
  </nav>
  {% endif %}

  {{ content | safe }}

  <!-- Footer -->
  <footer class="footer-section reveal">
    <div class="container">
      <h3 class="footer-title">Studio Stonehewer</h3>
      <p class="footer-desc">Interior design rooted in curated and expressive moments to tell the stories of your home.</p>
      <div class="footer-contact">
        <a href="mailto:studiostonehewer@gmail.com">STUDIOSTONEHEWER@GMAIL.COM</a>
        <a href="#">INSTAGRAM</a>
      </div>
      <div class="footer-links">
        {% for link in settings.nav_links %}
        <a href="{{ link.url }}">{{ link.label }}</a>
        {% endfor %}
      </div>
      <p class="copyright">© 2026 Studio Stonehewer. All rights reserved.</p>
    </div>
  </footer>

  <script src="/script.js"></script>
</body>
</html>
